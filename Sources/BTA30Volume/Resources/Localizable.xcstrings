      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Cihazı Kapat" } }
      }
    },
    "Press keys… ⎋" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Tuş bekleniyor… ⎋" } }
      }
    },
    "PRESETS" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "PRESET" } }
      }
    },
