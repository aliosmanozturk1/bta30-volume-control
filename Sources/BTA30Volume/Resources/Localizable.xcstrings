{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ is already assigned to another action." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "%@ zaten başka bir işleve atanmış." } }
      }
    },
    "A command didn't reach the device — re-syncing…" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Bir komut cihaza ulaşamadı — durum yeniden okunuyor…" } }
      }
    },
    "Active output: %@ — keys currently control system volume." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Aktif çıkış: %@ — tuşlar şu an sistem sesinde." } }
      }
    },
    "Allow \"BTA30 Volume\" in System Settings → Privacy & Security → Accessibility. Keys will activate automatically once permission is granted." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Sistem Ayarları → Gizlilik ve Güvenlik → Erişilebilirlik'te \"BTA30 Volume\"e izin verin. İzin verildiği anda tuşlar otomatik devreye girer." } }
      }
    },
    "another device" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "başka bir aygıt" } }
      }
    },
