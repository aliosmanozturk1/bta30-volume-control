        "tr" : { "stringUnit" : { "state" : "translated", "value" : "FiiO BTA30 Pro aranıyor…" } }
      }
    },
    "Make sure the device is powered on and the FiiO Control app on your phone is not connected." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Cihazın açık olduğundan ve telefondaki FiiO Control uygulamasının bağlı olmadığından emin olun." } }
