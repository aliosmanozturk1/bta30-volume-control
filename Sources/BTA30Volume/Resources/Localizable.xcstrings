      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Çıkış" } }
      }
    },
    "Ready in the menu bar when your Mac starts" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Mac açılınca menü çubuğunda hazır olur" } }
      }
    },
    "Reset to center" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ortaya sıfırla" } }
      }
    },
    "Restore defaults" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Varsayılanlara dön" } }
      }
    },
    "Save" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kaydet" } }
      }
    },
    "Save the current device settings (volume, filter, balance, LED, upsampling) under a name, then apply them with one click from the main screen." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Mevcut cihaz ayarlarını (ses, filtre, denge, LED, upsampling) isimle kaydedin; ana ekrandan tek tıkla uygulayın." } }
      }
    },
    "Saves the current settings under this name" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Mevcut ayarları bu adla saklar" } }
      }
    },
    "Scroll to adjust volume" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Scroll ile ses ayarı" } }
      }
    },
    "Settings" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ayarlar" } }
      }
    },
    "Shortcut must include at least ⌘, ⌥ or ⌃." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Kısayol en az ⌘, ⌥ veya ⌃ içermeli." } }
      }
    },
    "Space" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Boşluk" } }
      }
    },
    "Turn off LEDs" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "LED'leri kapat" } }
      }
    },
    "Turn the volume by scrolling over the menu bar icon" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Menü çubuğu simgesinin üzerinde kaydırınca ses değişir" } }
      }
    },
    "Turn on Bluetooth from Control Center." : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Denetim Merkezi'nden Bluetooth'u açın." } }
      }
    },
    "Unmute" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Sesi aç" } }
      }
    },
    "Upsampling" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Upsampling" } }
      }
    },
    "Upsamples the signal to 384 kHz" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Sinyali 384 kHz'e yükseltir" } }
      }
    },
    "Volume %lld · balance %lld · LED %@" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ses %1$lld · denge %2$lld · LED %3$@" } }
      }
    },
    "Volume keys control the device while FiiO is the active output" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ses tuşları, FiiO aktif çıkışken cihazı kontrol eder" } }
      }
    },
    "Volume limit" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Ses limiti" } }
      }
    },
    "Work in every app, no permission needed" : {
      "localizations" : {
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Her uygulamada çalışır, izin gerektirmez" } }
      }
    }
  },
  "version" : "1.0"
